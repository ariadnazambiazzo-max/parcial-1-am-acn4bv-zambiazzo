<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva Rutina"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textColor="#000000"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seleccioná los ejercicios que querés agregar"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"/>

        <!-- Ejercicio -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ejercicio"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spEjercicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp"/>

        <!-- Series -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Series"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/txtSeries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: 3"
            android:inputType="number"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"/>

        <!-- Repeticiones -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repeticiones"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/txtRepeticiones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: 15"
            android:inputType="number"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp"/>

        <!-- Botón agregar ejercicio -->
        <Button
            android:id="@+id/btnAgregar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregar ejercicio"
            android:backgroundTint="#954DCD"
            android:textColor="#FFFFFF"/>

        <!-- Lista de ejercicios agregados -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ejercicios agregados"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="10dp"/>

        <ListView
            android:id="@+id/listaRutina"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:divider="#DDDDDD"
            android:dividerHeight="1dp"/>

        <!-- Botones finales -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnGuardarRutina"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Guardar Rutina"
                android:backgroundTint="#28A745"
                android:textColor="#FFFFFF"/>

            <Space
                android:layout_width="16dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cancelar"
                android:backgroundTint="#D4000E"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>